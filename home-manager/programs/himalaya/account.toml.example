# ================================================================================
# Per-machine account config for himalaya — GMAIL TEMPLATE
#
# This file (the .example) is a placeholder-only template and is safe to commit.
# Copy it to the real, non-committed location and fill in your details:
#
#   cp account.toml.example ~/.config/himalaya/account.toml
#   $EDITOR ~/.config/himalaya/account.toml
#
# ~/.config/himalaya/account.toml is OUTSIDE the repo and is never committed.
# HIMALAYA_CONFIG deep-merges it on top of the committed theme config.toml.
#
# --------------------------------------------------------------------------------
# Gmail requires an App Password (not your normal password):
#   1. Enable 2-Step Verification:
#      https://myaccount.google.com/signinoptions/two-step-verification
#   2. Create an app password (name it "himalaya"):
#      https://myaccount.google.com/apppasswords
#   3. Use the 16-character value below (spaces removed).
# ================================================================================

[accounts.personal]
default = true
from = "you@gmail.com"
from-name = "Your Name"

# --- IMAP (receiving) ---
imap.server = "imaps://imap.gmail.com:993"
imap.sasl.plain.username = "you@gmail.com"

# --- SMTP (sending) ---
smtp.server = "smtps://smtp.gmail.com:465"
smtp.sasl.plain.username = "you@gmail.com"

# --- Password: pick ONE of the approaches below ---

# (a) Plaintext app password. Fine here since this file is never committed.
imap.sasl.plain.password.raw = "your16charapppassword"
smtp.sasl.plain.password.raw = "your16charapppassword"

# (b) macOS Keychain (no secret on disk). First store it once:
#       security add-generic-password -U -a "you@gmail.com" -s "himalaya" -w
#     then comment out the .raw lines above and use:
# imap.sasl.plain.password.command = "security find-generic-password -a 'you@gmail.com' -s 'himalaya' -w"
# smtp.sasl.plain.password.command = "security find-generic-password -a 'you@gmail.com' -s 'himalaya' -w"
